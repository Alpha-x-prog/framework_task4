            "method": "POST",
            "url": "{{base_url}}/event",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"process_key\": \"booking-001\",\n  \"event\": \"AcceptApplication\",\n  \"idempotency_key\": \"evt-001-1\",\n  \"correlation_id\": \"corr-001\"\n}"
            }
          }
        },
        {
